# Prontus.ai — variáveis de ambiente
# Copie para .env.local e preencha o que precisar. Tudo é OPCIONAL:
# o app roda 100% com dados mock e um copiloto (Íris) em modo simulado.

# --- Site ---
# URL pública do deploy (usada em metadata/OG, sitemap.xml e robots.txt).
NEXT_PUBLIC_SITE_URL=https://prontus.ai

# --- IA (Copiloto Íris) ---
# Sem chave, o copiloto responde com um fallback inteligente que lê os dados reais do app.
# Com chave, ele usa a Claude API (Messages API) de verdade.
ANTHROPIC_API_KEY=
# Modelo usado pelo copiloto quando há chave (padrão: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
