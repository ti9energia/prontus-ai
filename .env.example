# Prontus.ai — variáveis de ambiente
# Copie para .env.local (dev) e configure no Vercel (produção).

# --- Site ---
# URL pública do deploy (usada em metadata/OG, sitemap.xml e robots.txt).
NEXT_PUBLIC_SITE_URL=https://prontus.ai

# --- IA (Copiloto Mari) ---
# Sem chave, a Mari responde com um fallback inteligente que lê os dados reais do app.
# Com chave, ela usa a Claude API (Messages API) — apenas para usuários AUTENTICADOS.
ANTHROPIC_API_KEY=
# Modelo usado quando há chave (padrão: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Autenticação (sessões assinadas com HMAC) ---
# OBRIGATÓRIO em produção para habilitar o login do DONO. String longa e aleatória:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# Dono (super-admin) — login forte. Defina OWNER_PASSWORD_HASH (preferido) OU OWNER_PASSWORD.
# Sem AUTH_SECRET + senha do dono, o login do dono fica DESABILITADO (fail-closed).
OWNER_EMAIL=luiz.henriquelhm26@gmail.com
# Gere o hash:  node scripts/hash-password.mjs "sua-senha-forte"
OWNER_PASSWORD_HASH=
# Alternativa em texto puro (menos seguro que o hash):
OWNER_PASSWORD=

# Conta de teste (lado clínico / médico) — opcional. Padrões mostrados.
TEST_DOCTOR_EMAIL=marianabarreto@prontusai.com
TEST_DOCTOR_PASSWORD=prontus-demo
